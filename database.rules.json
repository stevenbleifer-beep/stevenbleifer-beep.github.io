{
  "rules": {
    "guestbook": {
      ".read": true,
      ".write": false,
      ".indexOn": ["timestamp"]
    },
    "visitorCount": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber() && newData.val() === data.val() + 1"
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
